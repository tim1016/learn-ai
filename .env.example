# Polygon.io API Configuration
# Get your API key from: https://polygon.io/dashboard/api-keys
POLYGON_API_KEY=your_polygon_api_key_here
FRED_API_KEY=your_fred_api_key_here

# PostgreSQL
POSTGRES_PASSWORD=mysecretpassword

# Redis backs local job state and SSE streams. Compose has a development
# fallback, but operators should set a real secret for any shared machine.
# Use URL-safe characters because compose injects this into Redis client URLs.
REDIS_PASSWORD=change-me-redis-password

# Local data-plane control guard. Compose passes this same value to the Python
# data plane and the Angular dev proxy; set a real value on shared machines.
DATA_PLANE_CONTROL_SECRET=local-dev-control-secret

# Local-only escape hatch for intentionally open experiments. Keep false for
# normal compose and any shared machine.
DATA_PLANE_ALLOW_UNAUTHENTICATED_CONTROL=false

# IBKR Gateway/TWS host allow-list for live-run start requests. The host daemon
# reads this repo-root .env value at startup (start-live-daemon.sh and the
# systemd installer pass --env-file .env). Defaults allow localhost plus the
# Podman/Docker host-gateway aliases. Add a literal host only when that gateway
# target is deliberately configured for this workstation.
# IBKR_HOST_ALLOWLIST=127.0.0.1,localhost,host.containers.internal,host.docker.internal

# IBKR Gateway client ids reserved for host-daemon-launched live bot children.
# This is separate from IBKR_CLIENT_ID, which belongs to the data-plane broker
# client. Use a range large enough for the number of concurrent bot processes
# you expect to run from the UI.
# LIVE_RUNNER_IBKR_CLIENT_ID_POOL=50-99

# LEAN Sidecar launcher URL (host process, not a compose container).
# The compose default ``http://host.containers.internal:8090`` works on
# Windows and Linux Podman via compose.yaml extra_hosts. Override only for
# non-standard runtimes — e.g. a remote launcher or a non-default port. Do
# not pin a machine-specific LAN IP. Verify reachability with
# ``GET /api/lean-sidecar/diagnose``.
# LEAN_LAUNCHER_URL=http://host.containers.internal:8090
