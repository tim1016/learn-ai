# Polygon.io API Configuration
# Get your API key from: https://polygon.io/dashboard/api-keys
POLYGON_API_KEY=your_polygon_api_key_here
FRED_API_KEY=your_fred_api_key_here

# PostgreSQL
POSTGRES_PASSWORD=mysecretpassword

# LEAN Sidecar launcher URL (host process, not a compose container).
# The compose default ``http://host.docker.internal:8090`` works on every
# supported runtime (Linux rootless Podman, Docker Desktop, WSL2). Override
# only for non-standard runtimes — e.g. a remote launcher or a non-default
# port. Verify reachability with ``GET /api/lean-sidecar/diagnose``.
# LEAN_LAUNCHER_URL=http://host.docker.internal:8090
