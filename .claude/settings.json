{
  "permissions": {
    "allow": [
      "WebFetch(domain:medium.com)",
      "Bash(podman start my-backend)"
    ]
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/post-edit-validate.sh",
            "statusMessage": "Validating edit...",
            "timeout": 120
          }
        ]
      }
    ]
  }
}
