node_modules/
bin/
obj/
.vs/
*.user
*.suo
*.lscache
appsettings.Development.json
.claude/worktrees/

# Local compose overrides (per-developer port remaps, mounts, etc.)
compose.override.yaml
compose.override.yml

# Environment variables (contains API keys)
.env

# Angular environment files (may contain API keys for development)
**/environments/environment.development.ts
**/environments/environment.production.local.ts
**/environments/.env*

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
env/
ENV/
.venv
*.egg-info/
dist/
build/

# ML trained models
trained_models/
!trained_models/.gitkeep
*.h5
*.keras

Frontend/.angular/

# Windows reserved device names (can be accidentally created)
nul

# Polygon-sourced LEAN cache (populated at runtime by the engine)
PythonDataService/lean-cache/
!PythonDataService/lean-cache/.gitkeep

# Derived analytics cache (parquet) — regenerated from Polygon data
PythonDataService/cache/

# Run-ledger artifacts (research-pipeline phase A) — persisted backtest
# runs under <run_id>/{ledger,result}.json. Recreated on demand from
# spec + data inputs.
PythonDataService/artifacts/

# Local agent skill cache (Codex CLI / agents tooling)
.agents/

# Playwright MCP session snapshots (transient browser-test artifacts)
.playwright-mcp/

# Claude Code runtime state
.claude/scheduled_tasks.lock

# Nested Claude runtime state created by local tool invocations.
PythonDataService/.claude/

# Superpowers tooling session cache
.superpowers/

# Scratch / temp working files (recursive — also catches subdirs)
**/Temp*.json

# IBKR snapshot data (runtime-generated Arrow files)
scripts/ibkr_snapshots/**/*.arrow

# Slice 1b: default host-bind dir for the data lake writer volume.
data-lake-volume/

# Cross-engine parity matrix: regen-script failure reports (runtime diagnostics).
PythonDataService/tests/fixtures/golden/cross-engine-studies/.failed/

# Local Polygon captures used during fixture/debug work.
PythonDataService/tests/fixtures/polygon_capture/

# host_daemon / launcher runtime artifacts (PID file + rotating launch log).
# Recreated on every launcher start; should never be committed.
PythonDataService/.launcher.log
PythonDataService/.launcher.pid

# Broker System v2 raw-capture journal (files-canonical JSONL, §6). Default
# BROKER_CAPTURE_DIR; verbatim vendor payloads, regenerable, never committed.
PythonDataService/var/broker_captures/
