*.h5
*.keras

Frontend/.angular/

# Windows reserved device names (can be accidentally created)
nul

# Polygon-sourced LEAN cache (populated at runtime by the engine)
PythonDataService/lean-cache/
!PythonDataService/lean-cache/.gitkeep

# Derived analytics cache (parquet) — regenerated from Polygon data
PythonDataService/cache/

# Run-ledger artifacts (research-pipeline phase A) — persisted backtest
# runs under <run_id>/{ledger,result}.json. Recreated on demand from
# spec + data inputs.
PythonDataService/artifacts/

# Local agent skill cache (Codex CLI / agents tooling)
.agents/

# Playwright MCP session snapshots (transient browser-test artifacts)
.playwright-mcp/

# Claude Code runtime state
.claude/scheduled_tasks.lock

# Superpowers tooling session cache
.superpowers/

# Scratch / temp working files
Temp*.json

# IBKR snapshot data (runtime-generated Arrow files)
scripts/ibkr_snapshots/**/*.arrow
