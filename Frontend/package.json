{
  "name": "frontend",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "npm run test:guards && ng test",
    "test:guards": "node scripts/verify-frontend-guards.cjs",
    "test:bot-control-harness": "node scripts/verify-bot-control-harness-guard.cjs",
    "test:proxy-control": "node scripts/verify-proxy-control-guard.cjs",
    "test:watch": "ng test --watch",
    "test:coverage": "ng test --coverage",
    "lint": "eslint src/ --max-warnings 0",
    "lint:fix": "eslint src/ --fix",
    "codegen:graphql": "graphql-codegen --config codegen.ts",
    "codegen:openapi": "openapi-typescript ../contracts/openapi/python-data-service.openapi.json --default-non-nullable=false -o src/app/api/broker.types.ts",
    "codegen": "npm run codegen:graphql && npm run codegen:openapi",
    "codegen:check": "npm run codegen && git diff --exit-code -- src/app/graphql/generated src/app/api/broker.types.ts",
    "e2e": "playwright test"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.0.0",
    "@angular/common": "^21.0.0",
    "@angular/compiler": "^21.0.0",
    "@angular/core": "^21.0.0",
    "@angular/forms": "^21.0.0",
    "@angular/platform-browser": "^21.0.0",
    "@angular/router": "^21.0.0",
    "@apollo/client": "^4.0.1",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/language": "^6.12.3",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.0",
    "@joint/core": "^4.3.0",
    "@polygon.io/client-js": "^8.2.0",
    "@primeuix/themes": "^2.0.3",
    "@tailwindcss/postcss": "^4.2.0",
    "apollo-angular": "^13.0.0",
    "chart.js": "^4.5.1",
    "dompurify": "^3.4.1",
    "echarts": "5.4.3",
    "echarts-gl": "2.0.9",
    "graphql": "^16.9.0",
    "katex": "^0.16.22",
    "lightweight-charts": "^5.1.0",
    "marked": "^18.0.2",
    "postcss": "^8.5.6",
    "primeicons": "^7.0.0",
    "primeng": "^21.1.1",
    "rxjs": "~7.8.0",
    "tailwindcss": "^4.2.0",
    "tslib": "^2.8.0",
    "zone.js": "~0.15.0",
    "zrender": "5.4.4"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^21.0.0",
    "@angular-eslint/eslint-plugin": "^21.3.1",
    "@angular-eslint/eslint-plugin-template": "^21.3.1",
    "@angular-eslint/template-parser": "^21.3.1",
    "@angular/cli": "^21.0.0",
    "@angular/compiler-cli": "^21.0.0",
    "@angular/platform-browser-dynamic": "^21.0.0",
    "@axe-core/playwright": "^4.12.1",
    "@eslint/js": "^10.0.1",
    "@graphql-codegen/cli": "^7.2.0",
    "@graphql-codegen/client-preset": "^6.1.0",
    "@playwright/test": "^1.49.1",
    "@testing-library/angular": "^17.3.7",
    "@testing-library/dom": "^10.4.0",
    "angular-eslint": "^21.3.1",
    "eslint": "^10.2.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "jsdom": "^26.1.0",
    "openapi-typescript": "^7.13.0",
    "typescript": "~5.9.0",
    "typescript-eslint": "^8.58.2",
    "vitest": "^4.0.8"
  }
}
