// Local-machine production environment override.
// Copy this file to `environment.production.local.ts` (gitignored) before
// running production builds (`ng build`, `ng build --configuration=production`).
//
// Why this file exists: the production build config in angular.json
// substitutes `environment.ts` with this file at compile time, so per-developer
// settings (e.g. a remapped backend host port to dodge macOS AirPlay on :5000)
// don't have to be committed.

export const environment = {
  production: true,
  polygonApiKey: '', // Leave empty — use backend proxy in production
  useBackendProxy: true, // Always use backend in production
  backendUrl: 'http://localhost:5000/graphql',
  polygonProxyUrl: 'http://localhost:5000/api/polygon', // Backend proxy endpoint
  pythonServiceUrl: 'http://localhost:8000',
  liveRunnerDaemonUrl: 'http://127.0.0.1:8765',
  flags: {
    replayInLeanEngine: true,
  },
};
